{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath') && bunx eslint --fix \"$f\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
